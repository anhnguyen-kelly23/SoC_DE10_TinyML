/*============================================================================
 * main.c — Nios II Firmware for MNIST MLP SoC
 *============================================================================
 * Receives a 28x28 grayscale image (784 bytes) via JTAG UART,
 * writes to the MLP Accelerator, triggers inference, and displays
 * the predicted digit on 7-segment display and UART.
 *
 * Build: Nios II Eclipse (SBT) with HAL BSP
 * Target: DE10-Standard (Cyclone V)
 *============================================================================*/

#include <stdio.h>
#include <stdint.h>
#include <string.h>
#include "system.h"
#include "io.h"
#include "alt_types.h"
#include "altera_avalon_jtag_uart_regs.h"

/*--- MLP Accelerator Register Offsets (byte address) ---*/
#define MLP_REG_CTRL     0x0000    /* W: bit0=START, bit1=SOFT_RESET */
#define MLP_REG_STATUS   0x0004    /* R: bit0=BUSY, bit1=DONE         */
#define MLP_REG_RESULT   0x0008    /* R: predicted digit 0-9           */
#define MLP_REG_SCORE    0x000C    /* R: max score (INT32)              */
#define MLP_REG_OUTPUT   0x0010    /* R: output[0]..output[9] (x4B)    */
#define MLP_REG_INPUT    0x1000    /* W: pixel[0]..pixel[783] (x4B)    */

#define MLP_CTRL_START   0x01
#define MLP_CTRL_RESET   0x02
#define MLP_STATUS_BUSY  0x01
#define MLP_STATUS_DONE  0x02

/*--- JTAG UART Helper: blocking read one byte ---*/
static alt_u8 jtag_uart_getchar(alt_u32 uart_base)
{
    alt_u32 data;
    /* Poll until data is available (bit 15 = RVALID) */
    do {
        data = IORD_ALTERA_AVALON_JTAG_UART_DATA(uart_base);
    } while (!(data & ALTERA_AVALON_JTAG_UART_DATA_RVALID_MSK));

    return (alt_u8)(data & ALTERA_AVALON_JTAG_UART_DATA_DATA_MSK);
}

/*--- JTAG UART Helper: blocking write one byte ---*/
static void jtag_uart_putchar(alt_u32 uart_base, alt_u8 ch)
{
    alt_u32 ctrl;
    /* Wait until write FIFO has space */
    do {
        ctrl = IORD_ALTERA_AVALON_JTAG_UART_CONTROL(uart_base);
    } while ((ctrl & ALTERA_AVALON_JTAG_UART_CONTROL_WSPACE_MSK) == 0);

    IOWR_ALTERA_AVALON_JTAG_UART_DATA(uart_base, ch);
}

/*--- Simple print string via JTAG UART ---*/
static void jtag_print(alt_u32 uart_base, const char *str)
{
    while (*str) {
        jtag_uart_putchar(uart_base, (alt_u8)*str++);
    }
}

/*--- Print decimal number ---*/
static void jtag_print_dec(alt_u32 uart_base, int val)
{
    char buf[12];
    int i = 0;
    int neg = 0;

    if (val < 0) {
        neg = 1;
        val = -val;
    }
    if (val == 0) {
        buf[i++] = '0';
    } else {
        while (val > 0) {
            buf[i++] = '0' + (val % 10);
            val /= 10;
        }
    }
    if (neg) buf[i++] = '-';

    /* Reverse print */
    while (i > 0) {
        jtag_uart_putchar(uart_base, (alt_u8)buf[--i]);
    }
}

/*--- MLP Accelerator Driver ---*/

static inline void mlp_soft_reset(alt_u32 base)
{
    IOWR_32DIRECT(base, MLP_REG_CTRL, MLP_CTRL_RESET);
}

static inline void mlp_write_pixel(alt_u32 base, int index, alt_u8 value)
{
    IOWR_32DIRECT(base, MLP_REG_INPUT + (index << 2), (alt_u32)value);
}

static inline void mlp_start(alt_u32 base)
{
    IOWR_32DIRECT(base, MLP_REG_CTRL, MLP_CTRL_START);
}

static inline int mlp_is_done(alt_u32 base)
{
    alt_u32 status = IORD_32DIRECT(base, MLP_REG_STATUS);
    return (status & MLP_STATUS_DONE) != 0;
}

static inline int mlp_get_result(alt_u32 base)
{
    return (int)(IORD_32DIRECT(base, MLP_REG_RESULT) & 0x0F);
}

static inline alt_32 mlp_get_score(alt_u32 base, int digit)
{
    return (alt_32)IORD_32DIRECT(base, MLP_REG_OUTPUT + (digit << 2));
}

/*--- Main ---*/

int main(void)
{
    /* Base addresses from system.h (Platform Designer generated) */
#ifdef MLP_ACCELERATOR_0_BASE
    const alt_u32 mlp_base = MLP_ACCELERATOR_0_BASE;
#else
    const alt_u32 mlp_base = 0x00010000;  /* Fallback */
#endif

#ifdef JTAG_UART_0_BASE
    const alt_u32 uart_base = JTAG_UART_0_BASE;
#else
    const alt_u32 uart_base = 0x00041000;  /* Fallback */
#endif

    int digit, i;
    alt_u8 pixel;
    alt_u8 image[784];

    jtag_print(uart_base, "\r\n");
    jtag_print(uart_base, "================================================\r\n");
    jtag_print(uart_base, "  MNIST Digit Recognition -- TinyML SoC\r\n");
    jtag_print(uart_base, "  MLP: 784 -> 128 (Leaky ReLU) -> 10\r\n");
    jtag_print(uart_base, "  Board: DE10-Standard (Cyclone V)\r\n");
    jtag_print(uart_base, "================================================\r\n\r\n");

    /* Initial reset */
    mlp_soft_reset(mlp_base);

    while (1) {
        jtag_print(uart_base, "Send 784 bytes (28x28 grayscale image)...\r\n");

        /* ---- Receive 784 bytes via JTAG UART ---- */
        for (i = 0; i < 784; i++) {
            image[i] = jtag_uart_getchar(uart_base);
        }
        jtag_print(uart_base, "Image received.\r\n");

        /* ---- Normalize and write to accelerator ---- */
        /* Input normalization: pixel / 2 -> maps [0,255] to [0,127] (INT8)
         * This matches the training normalization of [0,1] scaled by 127. */
        for (i = 0; i < 784; i++) {
            pixel = image[i] >> 1;  /* Simple /2 normalization */
            mlp_write_pixel(mlp_base, i, pixel);
        }

        /* ---- Start inference ---- */
        mlp_start(mlp_base);

        /* ---- Wait for completion ---- */
        while (!mlp_is_done(mlp_base)) {
            /* Busy-wait (~2ms @ 50MHz) */
        }

        /* ---- Read result ---- */
        digit = mlp_get_result(mlp_base);

        /* ---- Display on LEDs ---- */
#ifdef LED_BASE
        IOWR_32DIRECT(LED_BASE, 0, (1 << digit));
#endif

        /* ---- Print result ---- */
        jtag_print(uart_base, "\r\n  Predicted digit: ");
        jtag_print_dec(uart_base, digit);
        jtag_print(uart_base, "\r\n  Scores: ");
        for (i = 0; i < 10; i++) {
            jtag_print(uart_base, "[");
            jtag_print_dec(uart_base, i);
            jtag_print(uart_base, "]=");
            jtag_print_dec(uart_base, (int)mlp_get_score(mlp_base, i));
            jtag_print(uart_base, " ");
        }
        jtag_print(uart_base, "\r\n\r\n");

        /* Reset for next inference */
        mlp_soft_reset(mlp_base);
    }

    return 0;
}

